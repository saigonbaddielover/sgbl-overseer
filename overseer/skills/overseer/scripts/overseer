#!/usr/bin/env bash
# Read and drive another agent session (Claude Code or Codex) from outside it: a local or remote Linux
# tmux pane, or a console window on a remote Windows host over ssh (the win* commands).
# The controller is Linux-only (uses /proc). Requires: tmux, jq; ssh/scp for remote targets.
# Run OUTSIDE the target pane's tmux client.
set -eu

CLAUDE_HOME="${CLAUDE_HOME:-$HOME/.claude}"
CODEX_HOME="${CODEX_HOME:-$HOME/.codex}"
POLL_INTERVAL="${OVERSEER_POLL_INTERVAL:-0.25}"
DEFAULT_TIMEOUT="${OVERSEER_TIMEOUT:-600}"

_die() { printf 'overseer: %s\n' "$1" >&2; exit 1; }
_need() { command -v "$1" >/dev/null 2>&1 || _die "missing dependency: $1"; }
_uint() { case "${1:-}" in ''|*[!0-9]*) _die "timeout must be a whole number of seconds, got: '${1:-}'" ;; esac; }
_nap() { sleep "$POLL_INTERVAL"; }
case "$POLL_INTERVAL" in
  *[!0-9.]*|*.*.*|''|.) _die "OVERSEER_POLL_INTERVAL must be a positive number of seconds, got: '$POLL_INTERVAL'" ;;
esac
case "${POLL_INTERVAL//[.0]/}" in
  '') _die "OVERSEER_POLL_INTERVAL must be a positive number of seconds, got: '$POLL_INTERVAL'" ;;
esac
_uint "$DEFAULT_TIMEOUT"
if [ "${BASH_VERSINFO[0]:-0}" -lt 4 ] || { [ "${BASH_VERSINFO[0]}" -eq 4 ] && [ "${BASH_VERSINFO[1]:-0}" -lt 1 ]; }; then
  _die "needs bash >= 4.1 (found ${BASH_VERSION:-unknown}); on macOS install a newer bash (e.g. Homebrew) and run overseer under it"
fi

_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
# shellcheck source=lib/discovery.sh
. "$_dir/lib/discovery.sh"
# shellcheck source=lib/transcript.sh
. "$_dir/lib/transcript.sh"
# shellcheck source=lib/tui.sh
. "$_dir/lib/tui.sh"
# shellcheck source=lib/commands.sh
. "$_dir/lib/commands.sh"
# shellcheck source=lib/windows.sh
. "$_dir/lib/windows.sh"

main() {
  local cmd="${1:-}"; shift || true
  case "$cmd" in
    list) cmd_list "$@" ;;
    read) cmd_read "$@" ;;
    peek) cmd_peek "$@" ;;
    keys) cmd_keys "$@" ;;
    send) cmd_send "$@" ;;
    chat) cmd_chat "$@" ;;
    wait) cmd_wait "$@" ;;
    fleet) cmd_fleet "$@" ;;
    sh)   cmd_sh "$@" ;;
    quit) cmd_quit "$@" ;;
    start) cmd_start "$@" ;;
    stop) cmd_stop "$@" ;;
    slash) cmd_slash "$@" ;;
    menu) cmd_menu "$@" ;;
    doctor) cmd_doctor "$@" ;;
    on) cmd_on "$@" ;;
    deploy) cmd_deploy "$@" ;;
    hosts) cmd_hosts "$@" ;;
    provision) cmd_provision "$@" ;;
    winshow) cmd_winshow "$@" ;;
    winbroker) cmd_winbroker "$@" ;;
    winlist) cmd_winlist "$@" ;;
    winpeek) cmd_winpeek "$@" ;;
    winkeys) cmd_winkeys "$@" ;;
    winsh) cmd_winsh "$@" ;;
    winread) cmd_winread "$@" ;;
    winchat) cmd_winchat "$@" ;;
    winwait) cmd_winwait "$@" ;;
    winstop) cmd_winstop "$@" ;;
    ''|-h|--help)
      printf 'usage: overseer <command> [args]   (t = tmux pane id %%N or session name)\n'
      printf '  agent = a Claude Code OR Codex session; read/chat/send/wait auto-detect which.\n'
      printf '  list [--all]               agent panes + HARNESS (--all: every tmux pane + its command)\n'
      printf '  start <name> [shell|claude|codex] [workdir]  create a DETACHED tmux session running a shell/agent (attach to watch); same via "on <host> start ..."\n'
      printf '  stop  <t>                  kill the tmux session (or a %%N pane) and its child; refuses to kill the session overseer is in\n'
      printf '  read  <t>                  agent: last user prompt + last assistant reply (from transcript)\n'
      printf '  peek  [raw|-e] <t> [lines] full current screen (raw: keep colors -> see active tab/selection; [lines] applies to plain only)\n'
      printf '  chat  [--yes] [--force] <t> <msg|-> [timeout]  agent: send, wait for the reply, print it\n'
      printf '  send  [--yes] [--force] <t> <msg|->  agent: paste + verify + submit, confirm the turn started (no reply wait)\n'
      printf '  wait  <t> [timeout]        agent: block until the turn finishes\n'
      printf '  fleet [status|read|wait|send|chat] [args]  every agent pane at once (default status; send/chat broadcast)\n'
      printf '  quit  <t>                  agent: exit the TUI (claude Ctrl-C x2, codex x1), reveal the shell, keep tmux\n'
      printf '  slash <t> </cmd>           agent: run a slash command (/model /status ...; claude /resume /clear ...)\n'
      printf '  menu  <t> <item> [nav-key] any pane: navigate a tab/menu until <item> is highlighted (default key Right; codex popups are vertical -> pass Down)\n'
      printf '  sh    <t> <command> [timeout]        shell pane: run one line, wait, print output+exit\n'
      printf '  keys  <t> <key>...         raw keys to answer prompts/menus (Enter Escape y Up C-c ...)\n'
      printf '  doctor [--live]            preflight: Linux/proc, tmux, jq, session state; --live also drives a throwaway pane\n'
      printf '  deploy <host>              copy overseer to ~/.overseer on a remote ssh host (once, before "on")\n'
      printf '  on    <host> <command> [args]  run any overseer command on a remote ssh host (ControlPersist-reused; e.g. on sandbox chat %%0 hi)\n'
      printf '  hosts [--list] [--tailscale] [--os NAME] [-u USER] [-t secs]  survey the fleet: per host print user@host + online/os/ssh/drive-able (inventory from OVERSEER_HOSTS, ~/.ssh/config, or --tailscale; -u sets the login user for bare hosts)\n'
      printf '  provision [--dry-run] <host>  install the missing Linux drive deps (tmux+jq) on a remote ssh host (needs root/passwordless sudo); fixes a hosts DRIVE=no:tmux/no:jq\n'
      printf '  winshow <host> [app]       open a GUI app (default Windows Terminal) on the VISIBLE console session of a remote WINDOWS ssh host\n'
      printf '  winbroker <host>[/name] [pwsh|claude|codex] [workdir]  start a VISIBLE broker on a remote WINDOWS console hosting a shell/agent (/name to run several side by side)\n'
      printf '  winlist <host>             list the overseer brokers running on a remote WINDOWS host (name, child, alive)\n'
      printf '  winpeek <host>[/name]      snapshot the remote WINDOWS broker screen\n'
      printf '  winkeys <host>[/name] <key|text>...  send named keys (Enter Escape Up C-c ...) or literal text to the remote WINDOWS broker child\n'
      printf '  winsh <host>[/name] <command> [timeout]  run one command line in the remote WINDOWS broker pwsh child, wait, print output+exit\n'
      printf '  winread <host>[/name]      WINDOWS agent broker: last user prompt + last assistant reply (from transcript)\n'
      printf '  winchat [--yes] [--force] <host>[/name] <prompt|-> [timeout]  WINDOWS agent broker: send a prompt, wait the turn (transcript), print the reply\n'
      printf '  winwait <host>[/name] [timeout]  WINDOWS agent broker: block until the turn finishes\n'
      printf '  winstop <host>[/name]      stop the remote WINDOWS broker and its child\n'
      printf "  ('-' as <msg> reads the message from stdin; any length is pasted, not typed)\n"
      ;;
    *) _die "unknown command: $cmd" ;;
  esac
}
main "$@"
